///tile_mode_name(mode):name

switch (argument0) {
    case 1: return "Single"
    case 2: return "Grass Top"
    case 3: return "Pipes"
    case 4: return "9-Slice"
    case 5: return "16-Tile"
    case 6: return "47-Tile"
    case 7: return "Repeating Pattern"
    case 8: return "Random"
}

return "Disabled"
